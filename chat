                ImGui.PopStyleColor(2)
                
                if (i + 1) % cols ~= 0 and i < max_d - 1 then
                    ImGui.SameLine()
                end
            end
            
            ImGui.EndChild()
        end
        
    elseif state.main_category == 2 then
        local prop = prop_categories[state.selected_category]
        if prop then
            local max_d = GetPropDrawableCount(prop.id)
            
            ImGui.TextColored(colors.title[1], colors.title[2], colors.title[3], colors.title[4], prop.name)
            ImGui.SameLine()
            ImGui.SetCursorPosX(rightW - 160)
            ImGui.PushStyleColor(ImGuiCol.Button, colors.reset_btn[1], colors.reset_btn[2], colors.reset_btn[3], colors.reset_btn[4])
            ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.reset_hover[1], colors.reset_hover[2], colors.reset_hover[3], colors.reset_hover[4])
            if ImGui.Button("Reset", 65, 26) then
                ResetProp(prop.id)
            end
            ImGui.PopStyleColor(2)
            ImGui.SameLine()
            ImGui.PushStyleColor(ImGuiCol.Button, colors.remove_btn[1], colors.remove_btn[2], colors.remove_btn[3], colors.remove_btn[4])
            ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.cancel_hover[1], colors.cancel_hover[2], colors.cancel_hover[3], colors.cancel_hover[4])
            if ImGui.Button("Remove", 70, 26) then
                ApplyProp(prop.id, -1, 0)
                state.selected_prop_drawable = -1
                state.prop_drawable_input = "-1"
            end
            ImGui.PopStyleColor(2)
            
            ImGui.TextColored(colors.text_dim[1], colors.text_dim[2], colors.text_dim[3], colors.text_dim[4], max_d .. " models available")
            ImGui.Separator()
            ImGui.Spacing()
            
            if max_d > 0 then
                ImGui.Text("Model")
                ImGui.SameLine()
                ImGui.PushItemWidth(140)
                local old_d = state.selected_prop_drawable
                state.selected_prop_drawable = ImGui.SliderInt("##pdrawable", state.selected_prop_drawable, 0, max_d - 1, "%d")
                if old_d ~= state.selected_prop_drawable then
                    state.selected_prop_texture = 0
                    state.prop_drawable_input = tostring(state.selected_prop_drawable)
                    ApplyProp(prop.id, state.selected_prop_drawable, state.selected_prop_texture)
                end
                ImGui.PopItemWidth()
                ImGui.SameLine()
                ImGui.PushItemWidth(55)
                local new_inp = ImGui.InputText("##pinput", state.prop_drawable_input, 8)
                if new_inp ~= state.prop_drawable_input then
                    state.prop_drawable_input = new_inp
                    local n = tonumber(new_inp)
                    if n then
                        n = math.floor(math.max(0, math.min(n, max_d - 1)))
                        if n ~= state.selected_prop_drawable then
                            state.selected_prop_drawable = n
                            state.selected_prop_texture = 0
                            ApplyProp(prop.id, n, 0)
                        end
                    end
                end
                ImGui.PopItemWidth()
                
                local max_t = GetPropTextureCount(prop.id, state.selected_prop_drawable)
                if max_t < 1 then max_t = 1 end
                ImGui.Text("Texture")
                ImGui.SameLine()
                ImGui.PushItemWidth(195)
                local old_t = state.selected_prop_texture
                state.selected_prop_texture = ImGui.SliderInt("##ptexture", state.selected_prop_texture, 0, max_t - 1, "%d")
                if old_t ~= state.selected_prop_texture then
                    ApplyProp(prop.id, state.selected_prop_drawable, state.selected_prop_texture)
                end
                ImGui.PopItemWidth()
                
                ImGui.Spacing()
                ImGui.Separator()
                ImGui.Spacing()
                ImGui.TextColored(colors.subtitle[1], colors.subtitle[2], colors.subtitle[3], colors.subtitle[4], "Quick Select")
                ImGui.Spacing()
                
                ImGui.BeginChild("PropGrid", rightW - 20, rightH - 155, true)
                
                local cols = 3
                local btn_w = (rightW - 55) / cols
                local btn_h = 50
                
                for i = 0, max_d - 1 do
                    local is_eq = (state.selected_prop_drawable == i)
                    
                    if is_eq then
                        ImGui.PushStyleColor(ImGuiCol.Button, colors.btn_equipped[1], colors.btn_equipped[2], colors.btn_equipped[3], colors.btn_equipped[4])
                        ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.btn_equipped_hover[1], colors.btn_equipped_hover[2], colors.btn_equipped_hover[3], colors.btn_equipped_hover[4])
                    else
                        ImGui.PushStyleColor(ImGuiCol.Button, colors.btn_normal[1], colors.btn_normal[2], colors.btn_normal[3], colors.btn_normal[4])
                        ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.btn_hover[1], colors.btn_hover[2], colors.btn_hover[3], colors.btn_hover[4])
                    end
                    
                    local lbl = is_eq and "[ " .. i .. " ]" or "Model " .. i
                    
                    if ImGui.Button(lbl, btn_w - 8, btn_h) then
                        state.selected_prop_drawable = i
                        state.selected_prop_texture = 0
                        state.prop_drawable_input = tostring(i)
                        ApplyProp(prop.id, i, 0)
                    end
                    
                    ImGui.PopStyleColor(2)
                    
                    if (i + 1) % cols ~= 0 and i < max_d - 1 then
                        ImGui.SameLine()
                    end
                end
                
                ImGui.EndChild()
            else
                ImGui.Spacing()
                ImGui.TextColored(1.0, 0.5, 0.5, 1.0, "No props available for this category")
            end
        end
        
    else
        ImGui.TextColored(colors.title[1], colors.title[2], colors.title[3], colors.title[4], "Character Colors")
        ImGui.SameLine()
        ImGui.SetCursorPosX(rightW - 85)
        ImGui.PushStyleColor(ImGuiCol.Button, colors.reset_btn[1], colors.reset_btn[2], colors.reset_btn[3], colors.reset_btn[4])
        ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.reset_hover[1], colors.reset_hover[2], colors.reset_hover[3], colors.reset_hover[4])
        if ImGui.Button("Reset", 70, 26) then
            ResetColors()
        end
        ImGui.PopStyleColor(2)
        ImGui.Separator()
        ImGui.Spacing()
        ImGui.Spacing()
        
        ImGui.TextColored(colors.subtitle[1], colors.subtitle[2], colors.subtitle[3], colors.subtitle[4], "Hair Color - Primary")
        ImGui.PushItemWidth(rightW - 30)
        local old_hp = state.hair_color_primary
        state.hair_color_primary = ImGui.SliderInt("##hairp", state.hair_color_primary, 0, 63, "%d")
        if old_hp ~= state.hair_color_primary then
            ApplyColors()
        end
        ImGui.PopItemWidth()
        
        ImGui.Spacing()
        ImGui.Spacing()
        
        ImGui.TextColored(colors.subtitle[1], colors.subtitle[2], colors.subtitle[3], colors.subtitle[4], "Hair Color - Secondary (Highlights)")
        ImGui.PushItemWidth(rightW - 30)
        local old_hs = state.hair_color_secondary
        state.hair_color_secondary = ImGui.SliderInt("##hairs", state.hair_color_secondary, 0, 63, "%d")
        if old_hs ~= state.hair_color_secondary then
            ApplyColors()
        end
        ImGui.PopItemWidth()
        
        ImGui.Spacing()
        ImGui.Spacing()
        
        ImGui.TextColored(colors.subtitle[1], colors.subtitle[2], colors.subtitle[3], colors.subtitle[4], "Eye Color")
        ImGui.PushItemWidth(rightW - 30)
        local old_e = state.eye_color
        state.eye_color = ImGui.SliderInt("##eyec", state.eye_color, 0, 31, "%d")
        if old_e ~= state.eye_color then
            ApplyColors()
        end
        ImGui.PopItemWidth()
    end
    
    ImGui.EndChild()
    
    ImGui.Spacing()
    ImGui.Separator()
    ImGui.Spacing()
    
    ImGui.PushStyleColor(ImGuiCol.Button, colors.save_btn[1], colors.save_btn[2], colors.save_btn[3], colors.save_btn[4])
    ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.save_hover[1], colors.save_hover[2], colors.save_hover[3], colors.save_hover[4])
    if ImGui.Button("  Save Outfit  ", 150, 40) then
        SaveAllChanges()
    end
    ImGui.PopStyleColor(2)
    
    ImGui.SameLine()
    
    ImGui.PushStyleColor(ImGuiCol.Button, colors.cancel_btn[1], colors.cancel_btn[2], colors.cancel_btn[3], colors.cancel_btn[4])
    ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.cancel_hover[1], colors.cancel_hover[2], colors.cancel_hover[3], colors.cancel_hover[4])
    if ImGui.Button("  Cancel All  ", 150, 40) then
        CancelAllChanges()
    end
    ImGui.PopStyleColor(2)
    
    ImGui.SameLine()
    ImGui.SetCursorPosX(ww - 175)
    ImGui.TextColored(colors.text_dim[1], colors.text_dim[2], colors.text_dim[3], colors.text_dim[4], "Made by Weyzox & IA")
    
    ImGui.End()
    PopStyle()
end


local function OnRender()
    if hotkey_setup_mode then
        RenderHotkeySetup()
        return
    end
    
    if key_cooldown > 0 then
        key_cooldown = key_cooldown - 1
    end
    
    if assigned_hotkey and key_cooldown == 0 and Utils.IsKeyPressed(assigned_hotkey) then
        gui_open = not gui_open
        key_cooldown = 20
        
        if gui_open then
            SaveCurrentState()
            
            local c = clothing_categories[1]
            if c and state.current_outfit[c.id] then
                state.selected_drawable = state.current_outfit[c.id].drawable
                state.selected_texture = state.current_outfit[c.id].texture
                state.drawable_input = tostring(state.selected_drawable)
            end
        end
    end
    
    RenderMainGUI()
end

local handler = EventMgr.RegisterHandler(eLuaEvent.ON_PRESENT, OnRender)

GUI.AddToast("OutfitModeler", "Press any key to set hotkey", 4000, eToastPos.TOP_RIGHT)

EventMgr.RegisterHandler(eLuaEvent.ON_UNLOAD, function()
    EventMgr.RemoveHandler(handler)
end)
