local function RenderMainGUI()
    if gui_open == false then
        return
    end
    
    ShowCursorThisFrame()
    DisableCameraControls()
    
    ImGui.SetNextWindowSize(780, 720, ImGuiCond.FirstUseEver)
    ImGui.SetNextWindowPos(50, 50, ImGuiCond.FirstUseEver)
    
    PushStyle()
    
    ImGui.Begin(script_name .. " v" .. script_version, true, ImGuiWindowFlags.NoCollapse)
    
    local ww, wh = ImGui.GetWindowSize()
    ImGui.BeginChild("TopNav", ww - 16, 50, true)
    local tw = (ww - 50) / 3
    for i, cat in ipairs(main_categories) do
        if i > 1 then ImGui.SameLine() end
        
        if state.main_category == i then
            ImGui.PushStyleColor(ImGuiCol.Button, colors.tab_active[1], colors.tab_active[2], colors.tab_active[3], colors.tab_active[4])
            ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.tab_active[1], colors.tab_active[2], colors.tab_active[3], colors.tab_active[4])
        else
            ImGui.PushStyleColor(ImGuiCol.Button, colors.tab_inactive[1], colors.tab_inactive[2], colors.tab_inactive[3], colors.tab_inactive[4])
            ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.tab_hover[1], colors.tab_hover[2], colors.tab_hover[3], colors.tab_hover[4])
        end
        
        if ImGui.Button(cat.name, tw, 38) then
            state.main_category = i
            state.selected_category = 1
            
            if i == 1 then
                local c = clothing_categories[1]
                if c and state.current_outfit[c.id] then
                    state.selected_drawable = state.current_outfit[c.id].drawable
                    state.selected_texture = state.current_outfit[c.id].texture
                    state.drawable_input = tostring(state.selected_drawable)
                end
            elseif i == 2 then
                local p = prop_categories[1]
                if p and state.current_props[p.id] then
                    state.selected_prop_drawable = state.current_props[p.id].drawable
                    state.selected_prop_texture = state.current_props[p.id].texture
                    state.prop_drawable_input = tostring(state.selected_prop_drawable)
                end
            end
        end
        ImGui.PopStyleColor(2)
    end
    ImGui.EndChild()
    
    ImGui.Spacing()
    
    ImGui.BeginChild("CatList", 170, wh - 200, true)
    ImGui.TextColored(colors.subtitle[1], colors.subtitle[2], colors.subtitle[3], colors.subtitle[4], "  Categories")
    ImGui.Separator()
    ImGui.Spacing()
    
    local cats = {}
    if state.main_category == 1 then
        cats = clothing_categories
    elseif state.main_category == 2 then
        cats = prop_categories
    end
    
    for i, cat in ipairs(cats) do
        local display = " " .. cat.name
        if ImGui.Selectable(display, state.selected_category == i) then
            state.selected_category = i
            
            if state.main_category == 1 and state.current_outfit[cat.id] then
                state.selected_drawable = state.current_outfit[cat.id].drawable
                state.selected_texture = state.current_outfit[cat.id].texture
                state.drawable_input = tostring(state.selected_drawable)
            elseif state.main_category == 2 and state.current_props[cat.id] then
                state.selected_prop_drawable = state.current_props[cat.id].drawable
                state.selected_prop_texture = state.current_props[cat.id].texture
                state.prop_drawable_input = tostring(state.selected_prop_drawable)
            end
        end
    end
    ImGui.EndChild()
    
    ImGui.SameLine()
    
    local rightW = ww - 205
    local rightH = wh - 200
    ImGui.BeginChild("Controls", rightW, rightH, true)
    
    if state.main_category == 1 then
        local cat = clothing_categories[state.selected_category]
        if cat then
            local max_d = GetDrawableCount(cat.id)
            if max_d < 1 then max_d = 1 end
            
            ImGui.TextColored(colors.title[1], colors.title[2], colors.title[3], colors.title[4], cat.name)
            ImGui.SameLine()
            ImGui.SetCursorPosX(rightW - 85)
            ImGui.PushStyleColor(ImGuiCol.Button, colors.reset_btn[1], colors.reset_btn[2], colors.reset_btn[3], colors.reset_btn[4])
            ImGui.PushStyleColor(ImGuiCol.ButtonHovered, colors.reset_hover[1], colors.reset_hover[2], colors.reset_hover[3], colors.reset_hover[4])
            if ImGui.Button("Reset", 70, 26) then
                ResetClothing(cat.id)
            end
            ImGui.PopStyleColor(2)
            
            ImGui.TextColored(colors.text_dim[1], colors.text_dim[2], colors.text_dim[3], colors.text_dim[4], max_d .. " models available")
            ImGui.Separator()
            ImGui.Spacing()
            
            ImGui.Text("Model")
            ImGui.SameLine()
            ImGui.PushItemWidth(140)
            local old_d = state.selected_drawable
            state.selected_drawable = ImGui.SliderInt("##drawable", state.selected_drawable, 0, max_d - 1, "%d")
            if old_d ~= state.selected_drawable then
                state.selected_texture = 0
                state.drawable_input = tostring(state.selected_drawable)
                ApplyClothing(cat.id, state.selected_drawable, state.selected_texture)
            end
            ImGui.PopItemWidth()
