local function GetPed()
    return Natives.InvokeInt(PLAYER_PED_ID)
end

local function GetDrawableCount(cid)
    local ped = GetPed()
    if ped == 0 then return 0 end
    return Natives.InvokeInt(GET_NUMBER_OF_PED_DRAWABLE_VARIATIONS, ped, cid)
end

local function GetTextureCount(cid, d)
    local ped = GetPed()
    if ped == 0 then return 0 end
    local c = Natives.InvokeInt(GET_NUMBER_OF_PED_TEXTURE_VARIATIONS, ped, cid, d)
    if type(c) ~= "number" then return 0 end
    return c
end

local function GetPropDrawableCount(pid)
    local ped = GetPed()
    if ped == 0 then return 0 end
    return Natives.InvokeInt(GET_NUMBER_OF_PED_PROP_DRAWABLE_VARIATIONS, ped, pid)
end

local function GetPropTextureCount(pid, d)
    local ped = GetPed()
    if ped == 0 then return 0 end
    local c = Natives.InvokeInt(GET_NUMBER_OF_PED_PROP_TEXTURE_VARIATIONS, ped, pid, d)
    if type(c) ~= "number" then return 0 end
    return c
end

local function DetectKey()
    for vk, name in pairs(key_names) do
        if Utils.IsKeyPressed(vk) then
            return vk, name
        end
    end
    return nil, nil
end

local function ShowCursorThisFrame()
    Natives.InvokeVoid(SET_CURSOR_ACTIVE_THIS_FRAME)
end

local function DisableCameraControls()
    Natives.InvokeVoid(DISABLE_CONTROL_ACTION, 0, 1, true)  -- Look LR
    Natives.InvokeVoid(DISABLE_CONTROL_ACTION, 0, 2, true)  -- Look UD
    Natives.InvokeVoid(DISABLE_CONTROL_ACTION, 0, 25, true) -- Input Aim
end


local function ApplyClothing(cid, d, t)
    local ped = GetPed()
    if ped == 0 then return end
    Natives.InvokeVoid(SET_PED_COMPONENT_VARIATION, ped, cid, d, t, 0)
    state.current_outfit[cid] = {drawable = d, texture = t}
end

local function ApplyProp(pid, d, t)
    local ped = GetPed()
    if ped == 0 then return end
    if d == -1 then
        Natives.InvokeVoid(CLEAR_PED_PROP, ped, pid)
    else
        Natives.InvokeVoid(SET_PED_PROP_INDEX, ped, pid, d, t, true)
    end
    state.current_props[pid] = {drawable = d, texture = t}
end

local function ApplyColors()
    local ped = GetPed()
    if ped == 0 then return end
    Natives.InvokeVoid(SET_PED_HAIR_COLOR, ped, state.hair_color_primary, state.hair_color_secondary)
    Natives.InvokeVoid(SET_PED_EYE_COLOR, ped, state.eye_color)
end


local function SaveCurrentState()
    local ped = GetPed()
    if ped == 0 then return end
    
    state.original_outfit = {}
    state.current_outfit = {}
    for _, cat in ipairs(clothing_categories) do
        local d = Natives.InvokeInt(GET_PED_DRAWABLE_VARIATION, ped, cat.id)
        local t = Natives.InvokeInt(GET_PED_TEXTURE_VARIATION, ped, cat.id)
        state.original_outfit[cat.id] = {drawable = d, texture = t}
        state.current_outfit[cat.id] = {drawable = d, texture = t}
    end
    
    state.original_props = {}
    state.current_props = {}
    for _, prop in ipairs(prop_categories) do
        local d = Natives.InvokeInt(GET_PED_PROP_INDEX, ped, prop.id)
        local t = Natives.InvokeInt(GET_PED_PROP_TEXTURE_INDEX, ped, prop.id)
        state.original_props[prop.id] = {drawable = d, texture = t}
        state.current_props[prop.id] = {drawable = d, texture = t}
    end
    
    local hc = Natives.InvokeInt(GET_PED_HAIR_COLOR, ped)
    state.original_colors = {hair_primary = hc, hair_secondary = 0, eye = 0}
    state.hair_color_primary = hc
    state.hair_color_secondary = 0
    state.eye_color = 0
end

local function CancelAllChanges()
    local ped = GetPed()
    if ped == 0 then return end
    
    for cid, data in pairs(state.original_outfit) do
        Natives.InvokeVoid(SET_PED_COMPONENT_VARIATION, ped, cid, data.drawable, data.texture, 0)
        state.current_outfit[cid] = {drawable = data.drawable, texture = data.texture}
    end
    
    for pid, data in pairs(state.original_props) do
        if data.drawable == -1 then
            Natives.InvokeVoid(CLEAR_PED_PROP, ped, pid)
        else
            Natives.InvokeVoid(SET_PED_PROP_INDEX, ped, pid, data.drawable, data.texture, true)
        end
        state.current_props[pid] = {drawable = data.drawable, texture = data.texture}
    end
    
    Natives.InvokeVoid(SET_PED_HAIR_COLOR, ped, state.original_colors.hair_primary, state.original_colors.hair_secondary)
    Natives.InvokeVoid(SET_PED_EYE_COLOR, ped, state.original_colors.eye)
    
    state.hair_color_primary = state.original_colors.hair_primary
    state.hair_color_secondary = state.original_colors.hair_secondary
    state.eye_color = state.original_colors.eye
    
    local cat = clothing_categories[state.selected_category]
    if cat and state.current_outfit[cat.id] then
        state.selected_drawable = state.current_outfit[cat.id].drawable
        state.selected_texture = state.current_outfit[cat.id].texture
        state.drawable_input = tostring(state.selected_drawable)
    end
    
    GUI.AddToast("Cancelled", "Original outfit restored!", 2000, eToastPos.BOTTOM_RIGHT)
end

local function SaveAllChanges()
    for cid, data in pairs(state.current_outfit) do
        state.original_outfit[cid] = {drawable = data.drawable, texture = data.texture}
    end
    for pid, data in pairs(state.current_props) do
        state.original_props[pid] = {drawable = data.drawable, texture = data.texture}
    end
    state.original_colors = {
        hair_primary = state.hair_color_primary,
        hair_secondary = state.hair_color_secondary,
        eye = state.eye_color
    }
    GUI.AddToast("Saved", "Outfit saved!", 2000, eToastPos.BOTTOM_RIGHT)
end

local function ResetClothing(cid)
    local data = state.original_outfit[cid]
    if data then
        ApplyClothing(cid, data.drawable, data.texture)
        state.selected_drawable = data.drawable
        state.selected_texture = data.texture
        state.drawable_input = tostring(data.drawable)
        GUI.AddToast("Reset", "Category restored!", 1500, eToastPos.BOTTOM_RIGHT)
    end
end

local function ResetProp(pid)
    local data = state.original_props[pid]
    if data then
        ApplyProp(pid, data.drawable, data.texture)
        state.selected_prop_drawable = data.drawable
        state.selected_prop_texture = data.texture
        state.prop_drawable_input = tostring(data.drawable)
        GUI.AddToast("Reset", "Prop restored!", 1500, eToastPos.BOTTOM_RIGHT)
    end
end

local function ResetColors()
    state.hair_color_primary = state.original_colors.hair_primary
    state.hair_color_secondary = state.original_colors.hair_secondary
    state.eye_color = state.original_colors.eye
    ApplyColors()
    GUI.AddToast("Reset", "Colors restored!", 1500, eToastPos.BOTTOM_RIGHT)
end


